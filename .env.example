# Copy to `.env.local` for local development (never commit secrets).

# Supabase — Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Public anon key (browser-safe; optional for this app’s server-only API usage)
SUPABASE_ANON_KEY=your-anon-key
# Server-only: required for Next.js API routes to read/write with full access. Never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: one-time schema apply (npm run db:setup) — Supabase → Settings → Database → Connection string (URI)
# Use Direct or Session pooler; avoid Transaction pooler (6543) for DDL if it fails.
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# JWT signing (auth tokens)
JWT_SECRET=your_secure_random_string
SEED_ADMIN_KEY=set_a_random_admin_key_for_seed_and_test_routes

# Optional: email (SMTP) for verification emails
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
